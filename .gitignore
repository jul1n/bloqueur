# Cache HTTP (ETag/Last-Modified) — régénéré à chaque run, pas utile à versionner
.cache/

# Archives de configuration horodatées (--no-archive désactive déjà ça en CI,
# mais utile localement de ne pas les committer par erreur)
20*-*-*_*-*/

# Fichiers Python
__pycache__/
*.pyc

# Log détaillé (--log-file) : local, pas destiné à être versionné
run.log
*.log
